## Day--1
## #program1-->Mutable and Immutable Data Types in Python

# Immutable Data Types
user_name = "bhavni"              # str
user_age = 22                     # int
account_balance = 1500.75         # float
is_verified = True                # bool
coordinates = (17.3850, 78.4867)   # tuple

print("Immutable Types:")
print(type(user_name))
print(type(user_age))
print(type(account_balance))
print(type(is_verified))
print(type(coordinates))

# Mutable Data Types

skills = ["Python", "SQL"]        # list
unique_ids = {101, 102, 103}      # set
user_profile = {                  # dict
    "name": user_name,
    "age": user_age,
    "verified": is_verified
}

print("\nMutable Types:")
print(type(skills))
print(type(unique_ids))
print(type(user_profile))


# List modification
skills.append("Django")
print("\nUpdated Skills:", skills)

# Set modification
unique_ids.add(104)
print("Updated Unique IDs:", unique_ids)

# Dictionary modification
user_profile["verified"] = False
print("Updated User Profile:", user_profile)




