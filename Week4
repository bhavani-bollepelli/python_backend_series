##day9-->Shopping Cart System

def add_item(cart,price):
     cart.append(price)
     return cart
    
def get_totalcart(cart):
    total=sum(cart)
    return total
    
def apply_discount(total):
    if total>5000:
        return total*10/100
        
    else:
        print("No Distunt,Discount is on above 5000")
        return 0  
    
print("please enter the price (o to stop)")
cart=[]
while True:
        price=int(input("enter the price of item:"))
        

        if price==0:
            break

        add_item(cart,price)    
print(cart)
total=get_totalcart(cart)
discount=apply_discount(total)
final_price=total-discount

print("total price of cart is :",total)

print("total discount:",discount)

print("final price is :",final_price)



##Day-10-->Salary Calculator

def calculate_hra(basic):
    HRA=basic*20/100
    return HRA
def calculate_pf(basic):
    PF=basic*12/100
    return PF
def calculate_net(basic):

    HRA=calculate_hra(basic)
    PF=calculate_pf(basic)
    Net_Salary=basic+HRA-PF
    return Net_Salary
basic=int(input("enter basic salary:"))

net=calculate_net(basic)

    
print("basic salary:",basic)
print("HRA:",calculate_hra(basic))
print("PF:",calculate_pf(basic))
print("net salary:",net)
