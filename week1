### program3-->Number Reversal

n = int(input("Enter a number: "))

reverse = 0

while n > 0:
    digit = n % 10
    reverse = reverse * 10 + digit
    n = n // 10

print("Reversed number =", reverse)


## Day--5

### program1-->Prime Number

n = int(input("Enter a number: "))
count = 0

for i in range(1, n + 1):
    if n % i == 0:
        count += 1

if count == 2:
    print("Prime Number")
else:
    print("Not a Prime Number")


### program2-->Fibonacci Series

n = int(input("Enter number of terms: "))

a = 0
b = 1

for i in range(n):
    print(a, end=" ")
    c = a + b
    a = b
    b = c

### program3-->Find the Sum of Digits of a Number

n = int(input("Enter a number: "))
sum = 0

while n > 0:
    digit = n % 10
    sum += digit
    n = n // 10

print("Sum of digits:", sum)


### program4-->Palindrome Number

n = int(input("Enter a number: "))
original = n
reverse = 0

while n > 0:
    digit = n % 10
    reverse = reverse * 10 + digit
    n = n // 10

if original == reverse:
    print("Palindrome")
else:
    print("Not Palindrome")


### program5-->Armstrong Number

n = int(input("Enter a number: "))
original = n
sum = 0

while n > 0:
    digit = n % 10
    sum += digit ** 3
    n = n // 10

if original == sum:
    print("Armstrong Number")
else:
    print("Not Armstrong Number")


