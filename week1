### program1--> Multiplication Table of a Given Number up to a Specified Limit


n = int(input("Enter a number for multiplication: "))
m = int(input("Enter a number for where to stop multiplication: "))

for i in range(1, m + 1):
    print(f"{n} * {i} = {n * i}")


### program2-->Multiplication Tables of Multiple Numbers up to a Specified Limi


tables = input("Enter table numbers (space separated): ")
numbers = tables.split()

limit = int(input("Enter number to stop multiplication: "))

for num in numbers:
    n = int(num)
    print("\nTable of", n)
    
    for i in range(1, limit + 1):
        print(f"{n} * {i} = {n * i}")


